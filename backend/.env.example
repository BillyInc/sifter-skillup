# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=generate-a-strong-random-secret-here

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# ── Base / Blockchain ─────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────
WEB_DASHBOARD_URL=https://your-dashboard-domain.com

# ── App ───────────────────────────────────────────────────────
DEBUG=false

# ─── Portfolio Hub — Platform OAuth Credentials ───────────────────────────────
# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# GitHub (already used above — reuse same app credentials)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Twitter / X
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Meta (Instagram + Facebook — same app)
INSTAGRAM_CLIENT_ID=your_meta_app_id
INSTAGRAM_CLIENT_SECRET=your_meta_app_secret
FACEBOOK_APP_ID=your_meta_app_id
FACEBOOK_APP_SECRET=your_meta_app_secret

# Medium
MEDIUM_CLIENT_ID=your_medium_integration_client_id
MEDIUM_CLIENT_SECRET=your_medium_integration_client_secret

# Reddit
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret

# Behance (Adobe OAuth)
BEHANCE_CLIENT_ID=your_adobe_client_id
BEHANCE_CLIENT_SECRET=your_adobe_client_secret

# Dribbble
DRIBBBLE_CLIENT_ID=your_dribbble_client_id
DRIBBBLE_CLIENT_SECRET=your_dribbble_client_secret

# Google (YouTube)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Vimeo
VIMEO_CLIENT_ID=your_vimeo_client_id
VIMEO_CLIENT_SECRET=your_vimeo_client_secret

# API base URL (used for OAuth redirect URIs)
API_BASE_URL=https://api.sifter.app

# Anthropic — AI scoring (NEVER expose this in client code)
ANTHROPIC_API_KEY=sk-ant-your-key-here
